QOBUZ_AUTH_TOKENS = []

NEXT_PUBLIC_APPLICATION_NAME = Qobuz-DL
NEXT_PUBLIC_GITHUB = https://github.com/SouBryan/Bryan-DL

#Leave these empty unless you know what you're doing
CORS_PROXY = 
