# WARP IP rotation interval in seconds (default: 1800 = 30 min)
WARP_ROTATION_INTERVAL = 1800

# Apple Music rate limiting
APPLE_MUSIC_REQUEST_DELAY_MS = 500
APPLE_MUSIC_MAX_RETRIES_429 = 5
APPLE_MUSIC_MAX_CONCURRENT_DOWNLOADS = 2

# Apple Music account (for automatic cookie refresh)
# Leave empty to disable auto-refresh (manual cookie upload via SFTP)
APPLE_MUSIC_EMAIL = 
APPLE_MUSIC_PASSWORD = 
APPLE_MUSIC_COOKIE_REFRESH_HOURS = 12

# Cloudflare R2 (Apple Music cache)
R2_ACCOUNT_ID = 
R2_ACCESS_KEY_ID = 
R2_SECRET_ACCESS_KEY = 
R2_BUCKET_NAME = 
R2_PUBLIC_URL = 
R2_ENDPOINT_URL = 